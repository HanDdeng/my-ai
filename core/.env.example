# core 运行时配置。
PORT=8788
HOST=127.0.0.1
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,tauri://localhost
# LLM API key（openai-compatible provider 需要；留空 = mock 走回显）
# LLM_API_KEY=sk-...
# SQLite 文件路径（相对路径相对 cwd）；默认 ./core.db；测试可用 :memory:
CORE_DB_PATH=./core.db

# === v6.5 新增：LLM 超时 ===
# core → LLM 上游 (OpenAI / Ollama / vLLM 等) 请求超时（ms）。
# 必须 < gateway 的 CORE_TIMEOUT_MS（建议小 20-40s）。
# 默认 600000 = 10min，覆盖本地 Ollama 大模型推理。
LLM_TIMEOUT_MS=600000
