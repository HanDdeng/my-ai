# 统一编辑器行为：缩进用 2 空格，LF 换行，UTF-8，最后保留一个空行。
# 各 IDE / 编辑器会自动读取，少数老旧工具需安装 editorconfig 插件。

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Markdown 末尾允许保留两个空格作为硬换行标记，不裁剪尾随空格。
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
