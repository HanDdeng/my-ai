# 强制行尾 / 编码策略，防止 Git for Windows 的 core.autocrlf 把 shell 脚本
# 偷偷转成 CRLF，导致 husky 钩子报 `$'\r': command not found` 整段崩。

# 默认：让 git 自动判断（源码 UTF-8 / 文本文件走 LF，二进制按原样）。
* text=auto

# 显式锁 LF 的关键路径：
.husky/*              text eol=lf
*.sh                  text eol=lf
*.mts                 text eol=ts
*.cts                 text eol=ts
*.js                  text eol=lf
*.cjs                 text eol=lf
*.mjs                 text eol=lf
*.ts                  text eol=lf
*.tsx                 text eol=lf
*.jsx                 text eol=lf
*.json                text eol=lf
*.jsonc               text eol=lf
*.yml                 text eol=lf
*.yaml                text eol=lf
*.md                  text eol=lf
*.css                 text eol=lf
*.html                text eol=lf
.gitignore            text eol=lf
.gitattributes        text eol=lf
.editorconfig         text eol=lf
.prettierrc.json      text eol=lf
.prettierignore       text eol=lf

# 二进制：明确标 binary，不让 git 尝试 diff / 行尾转换。
*.png                 binary
*.jpg                 binary
*.jpeg                binary
*.gif                 binary
*.ico                 binary
*.icns                binary
*.webp                binary
*.woff                binary
*.woff2               binary
*.ttf                 binary
*.eot                 binary
*.mp4                 binary
*.webm                binary
*.wasm                binary
