{
  "name": "my-ai",
  "version": "0.0.0",
  "private": true,
  "description": "Desktop agent monorepo: client (Tauri+React), gateway, core.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "check:compat": "node scripts/check-compat-matrix.mjs versions/compat-matrix.json",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r exec rimraf dist node_modules .turbo",
    "setup": "node scripts/setup.mjs",
    "sync:compat": "node scripts/sync-compat.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.11.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "semver": "^7.6.3",
    "typescript": "^5.5.4",
    "vitest": "^2.1.4",
    "typescript-eslint": "^8.12.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,yml,yaml,md,css,html}": [
      "prettier --write"
    ]
  }
}
