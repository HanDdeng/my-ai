# 网关层运行时配置。
# 网关自身监听端口（前端默认指向 8787）。
PORT=8787
# 监听地址；127.0.0.1 仅本机访问，要跨机访问改为 0.0.0.0。
HOST=127.0.0.1
# 上游 core 的地址。
CORE_URL=http://127.0.0.1:8788
# pino 日志等级：fatal/error/warn/info/debug/trace。
LOG_LEVEL=info
# CORS 白名单，逗号分隔；包含 tauri:// 以便 Tauri Webview 直连。
CORS_ORIGINS=http://localhost:5173,tauri://localhost
