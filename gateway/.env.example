# 网关层运行时配置。
# 网关自身监听端口（前端默认指向 8787）。
PORT=8787
# 监听地址；127.0.0.1 仅本机访问，要跨机访问改为 0.0.0.0。
HOST=127.0.0.1
# 上游 core 的地址。
CORE_URL=http://127.0.0.1:8788
# pino 日志等级：fatal/error/warn/info/debug/trace。
LOG_LEVEL=info
# CORS 白名单，逗号分隔；包含 tauri:// 以便 Tauri Webview 直连。
CORS_ORIGINS=http://localhost:5173,tauri://localhost

# === v3 新增：远程配对与鉴权 ===
# 配对是否公开：true=任何客户端无需 key 即可配对；false=需要正确的 pair key
#   或 CLI 解析 code 流程（默认 false，适合家用/小团队）
GATEWAY_PAIRING_PUBLIC=false
# 网关层管理员通道 key：与客户端表单提交的 pairKey 匹配即直接配对
#   （任何模式下都 bypass code 流程；留空 = 不启用）
#   警告：此 key 走 HTTP 明文传输，HTTPS / 内网部署；明文 HTTP 跨网有泄露风险
# GATEWAY_PAIR_KEY=
# 客户端唯一键保存时效（秒）：超过此时长未活跃的 client 会被 cleanup 任务删除
#   留空 / 0 = 不启动清理任务（永久保留）
#   典型值：3600（1h）/ 86400（1d）/ 604800（1w）
# GATEWAY_PAIRING_KEY_TTL=
# SQLite DB 文件路径（相对路径相对 cwd）
GATEWAY_DB_PATH=./gateway.db
